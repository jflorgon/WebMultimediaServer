# Copia este fichero como `.env.tizen` y ajusta la IP del servidor.
# Vite carga estas variables al ejecutar `npm run build:tizen`.
# El fichero `.env.tizen` está en .gitignore (no se versiona).

# IP fija LAN del servidor MediaServerApi (puerto 5001 en el contenedor API).
VITE_API_URL=http://192.168.1.100:5001/api

# Activa HashRouter y base relativa para que la SPA funcione en file:// dentro del widget Tizen.
VITE_TIZEN=true
